OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.5
OPENAI_BASE_URL=
DATA_DIR=./data
DELIVERY_MODE=local
# DELIVERY_MODE=telegram
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
DAILY_PUSH_HOUR=9
